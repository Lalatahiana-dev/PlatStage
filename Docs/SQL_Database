•	Table conversations
CREATE TABLE conversations (
    id_conversation SERIAL PRIMARY KEY,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    id_student INT NOT NULL,
    id_company INT NOT NULL,
    id_offer INT NOT NULL,

    FOREIGN KEY (id_student)
        REFERENCES student_profiles(id_student),

    FOREIGN KEY (id_company)
        REFERENCES companies(id_company),

    FOREIGN KEY (id_offer)
        REFERENCES internship_offers(id_offer)
);

•	Table messages
CREATE TABLE messages (
    id_message SERIAL PRIMARY KEY,
    content TEXT NOT NULL,
    is_read BOOLEAN DEFAULT FALSE,
    sent_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    id_conversation INT NOT NULL,
    id_sender INT NOT NULL,

    FOREIGN KEY (id_conversation)
        REFERENCES conversations(id_conversation)
        ON DELETE CASCADE,

    FOREIGN KEY (id_sender)
        REFERENCES users(id_user)
        ON DELETE CASCADE
);

•	Table interviews
CREATE TABLE interviews (
    id_interview SERIAL PRIMARY KEY,
    scheduled_at TIMESTAMP NOT NULL,
    location VARCHAR(150),
    type VARCHAR(20)
        CHECK (type IN ('ONLINE','ON_SITE')),
    status VARCHAR(20)
        CHECK (status IN ('PENDING','CONFIRMED','CANCELLED')),
    id_application INT UNIQUE NOT NULL,

    FOREIGN KEY (id_application)
        REFERENCES applications(id_application)
        ON DELETE CASCADE
);


•	Table notifications
CREATE TABLE notifications (
    id_notification SERIAL PRIMARY KEY,
    title VARCHAR(150),
    content TEXT NOT NULL,
    type VARCHAR(50),
    is_read BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    id_user INT NOT NULL,

    FOREIGN KEY (id_user)
        REFERENCES users(id_user)
        ON DELETE CASCADE
);
